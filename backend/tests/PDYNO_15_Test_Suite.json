    {
      "name": "T6: POST /api/alerts — AlertStack push (LIFO alert creation)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('[T6] Status 201 — AlertStack push', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('[T6] Body has alert object with threshold', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('alert');",
              "  pm.expect(json.alert).to.have.property('threshold');",
              "  pm.expect(json.alert.threshold).to.eql(160.00);",

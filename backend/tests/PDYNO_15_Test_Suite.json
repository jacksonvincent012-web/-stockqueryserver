              "});",
              "pm.test('[T2] Updated price reflects new value', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.record.price).to.eql(185.20);",
              "});",
              "pm.test('[T2] Complexity: O(1) hash update < 50ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(50);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],

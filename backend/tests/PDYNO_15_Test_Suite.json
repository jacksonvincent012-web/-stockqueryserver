    {
      "name": "T8: GET /api/stocks/top?k=5 — TopKHeap ranking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('[T8] Status 200 — TopKHeap ranking', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('[T8] Returns array with k=5 items', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "  pm.expect(json.length).to.be.at.most(5);",
              "});",
              "pm.test('[T8] Items sorted descending by price', function () {",
              "  const json = pm.response.json();",
              "  if (json.length > 1) {",
              "    for (let i = 1; i < json.length; i++) {",
              "      pm.expect(json[i-1].price).to.be.at.least(json[i].price);",
              "    }",
              "  }",
              "});",
              "pm.test('[T8] Complexity: O(log k) per push < 100ms at N=10K', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(100);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/stocks/top?k=5",
          "host": ["{{base_url}}"],
          "path": ["api", "stocks", "top"],
          "query": [
            {
              "key": "k",
              "value": "5"
            }
          ]
        },
        "description": "TopKHeap retrieval: returns top K stocks by price using O(log K) heap extraction."
      }
    },

{
  "info": {
    "name": "PDYNO.3 — Stock Query Server 15-Test Suite",
    "description": "Comprehensive Postman test collection for the Stock Query Server API. Covers 7 DSA endpoints with success, validation, and error cases across N=100, 10K, 100K scales.\n\nPDYNO Squad: PDYNO.3 (API & Test Automation)\nTheme: C — Data Structures & Algorithm Visualization\n\nStructure:\n  Test 1–5   : Core DSA — StockHashMap, IngestionQueue, AlertStack\n  Test 6–10  : Core DSA — TopKHeap, SectorGraph, MergeSort, BinarySearch\n  Test 11–13 : Auth & Security — Login, role-based access, invalid token\n  Test 14–15 : System — Health check, benchmark endpoint\n\nEach test includes:\n  - Pre-request script for token injection (where required)\n  - JSON assertions on status code, response body, and latency logging\n  - pm.test blocks capturing N, operation, actual time (ms), and expected O(1) complexity",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "lastUpdated": "2026-06-22T07:53:00Z"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "N",
      "value": "100",
      "type": "string"
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// PDYNO.3 Global Pre-request: Log collection start",
          "console.log('=== PDYNO.3 Test Suite ===');",
          "console.log('Base URL: ' + pm.variables.get('base_url'));"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "T1: PUT /api/stocks — StockHashTable insert (N=100)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// StockHashMap: O(1) insert — PUT new stock record",
              "pm.variables.set('N', '100');",
              "const symbols = ['AAPL','GOOGL','MSFT','AMZN','NVDA','META','TSLA','JPM','V','JNJ'];",
              "const index = pm.iteration count > 0 ? Math.floor(Math.random() * 10) : 0;",
              "pm.variables.set('symbol', symbols[index]);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('[T1] Status 200 — StockHashMap insert', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('[T1] Body has symbol and data', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('symbol');",
              "  pm.expect(json).to.have.property('record');",
              "});",
              "pm.test('[T1] Complexity: O(1) expected < 50ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(50);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"symbol\": \"AAPL\",\n  \"price\": 178.50,\n  \"volume\": 25000000,\n  \"sector\": \"TECH\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/stocks",
          "host": ["{{base_url}}"],
          "path": ["api", "stocks"]
        },
        "description": "Tests StockHashMap O(1) insertion. Creates a stock record and verifies immediate retrieval."
      }
    },
    {
      "name": "T2: PUT /api/stocks — StockHashTable update existing (N=100)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('[T2] Status 200 — Hashmap update existing key', function () {",
